# ── Zenith Retail Cloud — frontend environment ──────────────────────────────
# Copy to `.env` (or `.env.local`) and fill in. All vars are baked into the
# build at compile time, so they must be PUBLIC values only (never secrets).
# Vite only exposes vars prefixed with VITE_.

# Base URL of the RASAP2 backend REST API. Include the scheme + host only;
# the client appends the `/api/v1` version prefix itself.
#   dev:     http://localhost:3000
#   staging: https://staging-api.your-domain.com
VITE_API_BASE_URL=http://localhost:3000

# Socket.io endpoint for realtime order/queue events. Usually the same host as
# the API. Leave blank to derive it from VITE_API_BASE_URL.
VITE_SOCKET_URL=

# Razorpay PUBLIC key id (test mode for MVP). Safe to ship to the client.
# The secret key lives ONLY on the backend — never put it here.
VITE_RAZORPAY_KEY_ID=

# Optional: default vendor id for single-tenant deploys / local testing.
VITE_DEFAULT_VENDOR_ID=
